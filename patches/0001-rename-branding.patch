diff --git a/tools/prepare_aster_logo.py b/tools/prepare_aster_logo.py
new file mode 100644
index 0000000000..f60c3b5e39
--- /dev/null
+++ b/tools/prepare_aster_logo.py
@@ -0,0 +1,216 @@
+#!/usr/bin/env python3
+"""Prepare and install Aster logo assets for a Chromium checkout."""
+
+from __future__ import annotations
+
+import argparse
+import datetime as _dt
+import re
+import shutil
+import sys
+from pathlib import Path
+
+from PIL import Image, ImageChops
+
+
+SIZES = (16, 24, 32, 48, 64, 128, 256)
+MASTER_SIZE = 1024
+LOGO_SCALE = 0.78
+PRODUCT_LOGO_RE = re.compile(r"^product_logo_(\d+)\.png$")
+
+
+def fail(message: str) -> None:
+    raise SystemExit(f"ERROR: {message}")
+
+
+def repo_root_from_args(value: str | None) -> Path:
+    root = Path(value).resolve() if value else Path.cwd().resolve()
+    if not (root / "chrome" / "app").exists():
+        fail(f"Chromium source root not found: {root}")
+    return root
+
+
+def ensure_rgba(path: Path) -> Image.Image:
+    if not path.exists():
+        fail(f"Input logo file does not exist: {path}")
+    try:
+        image = Image.open(path)
+        image.load()
+    except Exception as exc:
+        fail(f"Could not open input logo: {path} ({exc})")
+    return image.convert("RGBA")
+
+
+def alpha_or_background_mask(image: Image.Image) -> Image.Image:
+    alpha = image.getchannel("A")
+    alpha_min, alpha_max = alpha.getextrema()
+    if alpha.getbbox() and alpha_min != alpha_max:
+        return alpha
+
+    # Fallback for opaque exports: remove a nearly uniform corner background.
+    corners = [
+        image.getpixel((0, 0)),
+        image.getpixel((image.width - 1, 0)),
+        image.getpixel((0, image.height - 1)),
+        image.getpixel((image.width - 1, image.height - 1)),
+    ]
+    bg = tuple(sum(c[i] for c in corners) // len(corners) for i in range(3))
+    rgb = Image.new("RGBA", image.size, bg + (255,))
+    diff = ImageChops.difference(image, rgb).convert("L")
+    return diff.point(lambda p: 0 if p < 20 else 255)
+
+
+def make_master(image: Image.Image) -> Image.Image:
+    mask = alpha_or_background_mask(image)
+    bbox = mask.getbbox()
+    if not bbox:
+        fail("Input image has no visible non-transparent content")
+
+    cropped = image.crop(bbox)
+    content_target = int(MASTER_SIZE * LOGO_SCALE)
+    ratio = min(content_target / cropped.width, content_target / cropped.height)
+    resized = cropped.resize(
+        (max(1, round(cropped.width * ratio)), max(1, round(cropped.height * ratio))),
+        Image.Resampling.LANCZOS,
+    )
+
+    canvas = Image.new("RGBA", (MASTER_SIZE, MASTER_SIZE), (0, 0, 0, 0))
+    offset = ((MASTER_SIZE - resized.width) // 2, (MASTER_SIZE - resized.height) // 2)
+    canvas.alpha_composite(resized, offset)
+    if canvas.size != (MASTER_SIZE, MASTER_SIZE):
+        fail("Internal error: normalized canvas is not 1024x1024")
+    if canvas.getchannel("A").getbbox() is None:
+        fail("Internal error: normalized canvas is fully transparent")
+    return canvas
+
+
+def write_pngs(master: Image.Image, generated_dir: Path) -> dict[int, Path]:
+    generated_dir.mkdir(parents=True, exist_ok=True)
+    master_path = generated_dir / "aster_logo_master_1024.png"
+    master.save(master_path, "PNG")
+    if Image.open(master_path).size != (MASTER_SIZE, MASTER_SIZE):
+        fail(f"Generated master has wrong size: {master_path}")
+
+    outputs: dict[int, Path] = {}
+    for size in SIZES:
+        out = generated_dir / f"aster_logo_{size}.png"
+        resized = master.resize((size, size), Image.Resampling.LANCZOS)
+        resized.save(out, "PNG", optimize=True)
+        with Image.open(out) as check:
+            if check.size != (size, size):
+                fail(f"Generated PNG has wrong size: {out} -> {check.size}")
+            if check.mode not in ("RGBA", "LA", "P"):
+                fail(f"Generated PNG does not preserve alpha-capable mode: {out}")
+        outputs[size] = out
+    return outputs
+
+
+def write_ico(pngs: dict[int, Path], generated_dir: Path) -> Path:
+    ico_path = generated_dir / "aster.ico"
+    images = [Image.open(pngs[size]).convert("RGBA") for size in SIZES]
+    images[-1].save(
+        ico_path,
+        format="ICO",
+        sizes=[(size, size) for size in SIZES],
+        append_images=images[:-1],
+    )
+    with Image.open(ico_path) as check:
+        sizes = set(check.ico.sizes())
+    expected = {(size, size) for size in SIZES}
+    if sizes != expected:
+        fail(f"ICO size set mismatch: got {sorted(sizes)}, expected {sorted(expected)}")
+    return ico_path
+
+
+def find_product_logo_targets(root: Path) -> list[Path]:
+    targets: list[Path] = []
+    for path in (root / "chrome" / "app" / "theme").rglob("product_logo_*.png"):
+        if PRODUCT_LOGO_RE.match(path.name):
+            targets.append(path)
+    return sorted(targets)
+
+
+def find_ico_targets(root: Path) -> list[Path]:
+    return sorted((root / "chrome" / "app" / "theme").rglob("chromium.ico"))
+
+
+def backup_path_for(target: Path, root: Path, backup_dir: Path) -> Path:
+    relative = target.relative_to(root)
+    return backup_dir / relative
+
+
+def install_assets(root: Path, pngs: dict[int, Path], ico_path: Path, dry_run: bool) -> list[Path]:
+    timestamp = _dt.datetime.now().strftime("%Y%m%d-%H%M%S")
+    backup_dir = root / "branding" / "backup" / timestamp
+    modified: list[Path] = []
+    replacements: list[tuple[Path, Path]] = []
+
+    for target in find_product_logo_targets(root):
+        with Image.open(target) as check:
+            target_size = check.size
+        if target_size[0] == target_size[1] and target_size[0] in pngs:
+            replacements.append((target, pngs[target_size[0]]))
+
+    ico_targets = find_ico_targets(root)
+    if not ico_targets:
+        fail("No chromium.ico target found under chrome/app/theme")
+    replacements.extend((target, ico_path) for target in ico_targets)
+
+    if dry_run:
+        return [target for target, _ in replacements]
+
+    copied: list[Path] = []
+    try:
+        for target, _ in replacements:
+            backup = backup_path_for(target, root, backup_dir)
+            backup.parent.mkdir(parents=True, exist_ok=True)
+            shutil.copy2(target, backup)
+
+        for target, source in replacements:
+            shutil.copy2(source, target)
+            copied.append(target)
+            modified.append(target)
+    except Exception:
+        for target in copied:
+            backup = backup_path_for(target, root, backup_dir)
+            if backup.exists():
+                shutil.copy2(backup, target)
+        raise
+
+    return modified
+
+
+def main(argv: list[str]) -> int:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("input_png", help="Path to the source Aster logo PNG")
+    parser.add_argument("--src-root", default=None, help="Chromium source root; defaults to cwd")
+    parser.add_argument("--dry-run", action="store_true", help="Only print replacement targets")
+    args = parser.parse_args(argv)
+
+    root = repo_root_from_args(args.src_root)
+    input_path = Path(args.input_png).resolve()
+    generated_dir = root / "branding" / "generated"
+
+    image = ensure_rgba(input_path)
+    print(f"Input: {input_path}")
+    print(f"Input image: mode={image.mode}, size={image.size}, alpha={image.getchannel('A').getextrema()}")
+
+    master = make_master(image)
+    pngs = write_pngs(master, generated_dir)
+    ico_path = write_ico(pngs, generated_dir)
+    modified = install_assets(root, pngs, ico_path, args.dry_run)
+
+    print(f"Generated: {generated_dir / 'aster_logo_master_1024.png'}")
+    for size in SIZES:
+        print(f"Generated: {pngs[size]}")
+    print(f"Generated: {ico_path}")
+    print("Replacement targets:")
+    for path in modified:
+        print(f"  {path.relative_to(root)}")
+    if not args.dry_run:
+        print("Backups were written under branding/backup/<timestamp>/")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main(sys.argv[1:]))
